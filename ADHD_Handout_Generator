document.addEventListener('DOMContentLoaded', () => {
  // Pre-set ALL sections as excluded, then un-exclude only Brief Explainer
  SECTIONS.forEach(s => { sectionExcluded[s.id] = true; });
  activePresets['brief'] = true;
  (PRESETS['brief'] || []).forEach(id => { sectionExcluded[id] = false; });
  // buildSectionBubbles will now see sectionExcluded already populated and skip reinit
  buildSectionBubbles();
  // Mark the brief button as active visually
  const briefBtn = document.querySelector('.preset-btn[data-preset="brief"]');
  if (briefBtn) briefBtn.classList.add('active');
  renderPhases();
  document.getElementById('patient-date').value = new Date().toISOString().slice(0,10);
  // Hide all output panes except rich
  ['output-tit-only','output-long','output-script','output-plain'].forEach(id => {
    document.getElementById(id).style.display = 'none';
  });
});
