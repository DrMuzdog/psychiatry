      const phaseLabel = ph.label || 'Phase ' + (pi+1);
      let durationDays = ph.ongoing ? null : (ph.unit === 'weeks' ? (ph.duration||1)*7 : (ph.duration||1));
      const phaseDoseCols = ph.meds.reduce((acc, m) => acc + m.doses.length, 0);
      const padCols = maxDoseCols - phaseDoseCols; // padding columns for uniform width

      // Phase header row
      let phLabel = phaseLabel;
      if (!ph.ongoing && durationDays) phLabel += ` — ${ph.duration} ${ph.unit}`;
      if (ph.ongoing) phLabel += ` — ongoing / until next review`;
      h += `<tr><td ${TD_PHASE} colspan="${spanCols}">${phLabel}`;
      if (ph.note) h += `<span style="font-weight:400;font-size:9pt;opacity:0.85;margin-left:8pt;">${ph.note}</span>`;
      h += `</td></tr>`;

      // Column headers for this phase
      const timingHeaders = ph.meds.map(med =>
        med.doses.map(d => `<th ${TH}>${d.time}</th>`).join('')
      ).join('');
      const padHeaders = padCols > 0 ? `<th ${TH} colspan="${padCols}"></th>` : '';
      h += `<tr>${showTick ? `<th ${TH_TICK}>&#10003;</th>` : ''}<th ${TH_DAY}>Day</th>${timingHeaders}${padHeaders}</tr>`;

      // Day rows
      const rowCount = ph.ongoing ? 7 : (durationDays || 7);
      for (let d = 1; d <= rowCount; d++) {
        dayCount++;
        const isLast = ph.ongoing && d === rowCount;
        const dayLabel = isLast ? `Day ${dayCount}+` : `Day ${dayCount}`;
        const isDay20 = dayCount === 20;
        const rowBg = isDay20 ? 'background:#FFF3CD;' : (d % 2 === 0 ? 'background:#f5f8ff;' : '');
        const tdDayStyle = isDay20
          ? 'style="border:1pt solid #c8d8ee;padding:3pt 5pt;font-family:Arial,sans-serif;font-size:9pt;font-weight:600;color:#7A4000;white-space:nowrap;text-align:left;background:#FFF3CD;"'
          : TD_DAY;
        h += `<tr style="${rowBg}">`;
        if (showTick) h += `<td ${TD_TICK}><input type="checkbox" style="width:14px;height:14px;"></td>`;
        h += `<td ${tdDayStyle}>${dayLabel}${isDay20 ? ' &#128197;' : ''}</td>`;
        ph.meds.forEach(med => {
          const def = MEDS[med.medId];
          med.doses.forEach(dose => {
            const cellStyle = isDay20
              ? 'style="border:1pt solid #c8d8ee;padding:3pt 5pt;font-family:Arial,sans-serif;font-size:9pt;text-align:center;vertical-align:middle;background:#FFF3CD;"'
              : TD;
            h += `<td ${cellStyle}>${getDoseDisplay(dose, def)}</td>`;
          });
        });
        if (padCols > 0) h += `<td ${TD} colspan="${padCols}"></td>`;
        h += `</tr>`;
        if (isDay20) {
          h += `<tr><td ${TD_DAY20}>&#128197; Day 20: time to request your next script from the pharmacy.</td></tr>`;
        }
      }
      if (ph.ongoing) {
        h += `<tr><td ${TD_CONT}>Continue at this dose until next review with your psychiatrist</td></tr>`;
      }
    });
  } else {
    // MEDICATION PLAN MODE: rows = days, columns = unique time slots across all meds
    // Find all unique time slots across ALL phases to keep a consistent column set
    const allTimeSlotsSet = new Set();
    phases.forEach(ph => ph.meds.forEach(med => med.doses.forEach(d => allTimeSlotsSet.add(d.time))));
    // Order time slots by natural day order
    const TIME_ORDER = ['morning','midday','afternoon','evening','night','bedtime','with breakfast','with lunch','with dinner'];
    const allTimeSlots = [...allTimeSlotsSet].sort((a, b) => {
      const ai = TIME_ORDER.indexOf(a.toLowerCase()), bi = TIME_ORDER.indexOf(b.toLowerCase());
      if (ai === -1 && bi === -1) return a.localeCompare(b);
      if (ai === -1) return 1;
      if (bi === -1) return -1;
      return ai - bi;
    });
    const planSpanCols = (showTick ? 2 : 1) + allTimeSlots.length;

    // TD_CELL: left-aligned, allows med name stacking
    const TD_CELL = 'style="border:1pt solid #c8d8ee;padding:3pt 5pt;font-family:Arial,sans-serif;font-size:9pt;text-align:left;vertical-align:top;"';

    // Column headers row (once, at the top)
    const timeHeaders = allTimeSlots.map(t => `<th ${TH}>${t}</th>`).join('');
    h += `<tr>${showTick ? `<th ${TH_TICK}>&#10003;</th>` : ''}<th ${TH_DAY}>Day</th>${timeHeaders}</tr>`;

    phases.forEach((ph, pi) => {
      const phaseLabel = ph.label || 'Group ' + (pi+1);
      const daysToShow = (ph.days && ph.days.length > 0) ? ph.days : DOW_NAMES;

      // Group header row (spans full width)
      h += `<tr><td ${TD_PHASE} colspan="${planSpanCols}">${phaseLabel}`;
      if (ph.note) h += `<span style="font-weight:400;font-size:9pt;opacity:0.85;margin-left:8pt;">${ph.note}</span>`;
      h += `</td></tr>`;

      // Build a lookup: timeSlot -> list of "MedName: dose" strings for this group
      const timeMap = {};
      allTimeSlots.forEach(t => { timeMap[t] = []; });
      ph.meds.forEach(med => {
        const def = MEDS[med.medId];
        if (!def) return;
        med.doses.forEach(dose => {
          if (timeMap[dose.time] !== undefined) {
            const doseStr = getDoseDisplay(dose, def);
            timeMap[dose.time].push(`<span style="font-style:italic;color:#555;">${def.name}:</span> ${doseStr}`);
          }
        });
      });

      daysToShow.forEach((day, di) => {
        const rowBg = di % 2 === 0 ? '' : 'background:#f5f8ff;';
        h += `<tr style="${rowBg}">`;
        if (showTick) h += `<td ${TD_TICK}><input type="checkbox" style="width:14px;height:14px;"></td>`;
        h += `<td ${TD_DAY}>${day}</td>`;
        allTimeSlots.forEach(t => {
          const entries = timeMap[t];
          h += `<td ${TD_CELL}>${entries.length ? entries.join('<br>') : '<span style="color:#ccc;">—</span>'}</td>`;
        });
        h += `</tr>`;
      });
    });
  }

  h += `</tbody></table>`;
  return h;
}

// Helpers to render a human-readable dose string for script text
function qtyToWords(qty) {
  if (qty === 0.25) return 'a quarter of a tab';
  if (qty === 0.5) return 'half a tab';
  if (qty === 0.75) return 'three-quarters of a tab';
  if (qty === 1) return 'one tab';
  if (qty === 1.5) return 'one and a half tabs';
  if (qty === 2) return 'two tabs';
  if (qty === 2.5) return 'two and a half tabs';
  if (qty === 3) return 'three tabs';
  if (qty === 4) return 'four tabs';
  return qty + ' tab(s)';
}

function doseToScriptPhrase(dose, medDef) {
  if (medDef.multiCap) {
    const caps = dose.caps || [];
    const total = caps.reduce((a,b)=>a+b,0);
    return caps.length > 1 ? `${caps.join(' mg + ')} mg (${total} mg total)` : `${total} mg`;
  }
  if (medDef.freeTextDose) return dose.label || '(dose)';
  if (dose.label) {
    // Extract the human part before the bracket e.g. "1½ tabs" from "1½ tabs (15 mg)"
    const m = dose.label.match(/^([^(]+)/);
    return m ? m[1].trim() : dose.label;
  }
  if (dose.qty !== undefined) return qtyToWords(dose.qty);
  return '(dose)';
}

// Build script text - plain, clean format for authority script
function buildScriptText() {
  if (!phases.length) return 'No plan configured.';
  const isTitration = planMode === 'titration';
  let txt = '';

  if (isTitration) {
    let dayCount = 0;
    phases.forEach((ph) => {
      const durationDays = ph.ongoing ? null : (ph.unit === 'weeks' ? (ph.duration||1)*7 : (ph.duration||1));
      const startDay = dayCount + 1;
      if (!ph.ongoing && durationDays) {
        const endDay = dayCount + durationDays;
        dayCount += durationDays;
        const dayRange = startDay === endDay ? `Day ${startDay}` : `Days ${startDay}${endDay > startDay+1 ? '-' : ', '}${endDay}`;
        ph.meds.forEach(med => {
          const def = MEDS[med.medId];
          if (!def) return;
          const doseLines = med.doses.map(d => `${doseToScriptPhrase(d, def)} ${d.time}`).join(', ');
          txt += `${dayRange}: ${def.name} — ${doseLines}\n`;
        });
      } else {
        // ongoing
        ph.meds.forEach(med => {
          const def = MEDS[med.medId];
          if (!def) return;
          const doseLines = med.doses.map(d => `${doseToScriptPhrase(d, def)} ${d.time}`).join(', ');
          txt += `Day ${startDay}+: ${def.name} — ${doseLines} (ongoing / until next review)\n`;
        });
      }
    });
  } else {
    // Medication plan: list medications directly
    phases.forEach((ph) => {
      if (ph.label) txt += `${ph.label}:\n`;
      ph.meds.forEach(med => {
        const def = MEDS[med.medId];
        if (!def) return;
        const doseLines = med.doses.map(d => `${doseToScriptPhrase(d, def)} ${d.time}`).join(', ');
        txt += `${def.name} — ${doseLines}\n`;
      });
      txt += '\n';
    });
  }

  return txt.trim();
}

