function switchOutputTabById(tab) {
  const allDivs = { rich: 'output-rich', tit: 'output-tit-only', long: 'output-long', script: 'output-script', plain: 'output-plain' };
  Object.entries(allDivs).forEach(([t, id]) => {
    document.getElementById(id).style.display = t === tab ? 'block' : 'none';
  });
