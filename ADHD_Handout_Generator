      ${clinician ? `<strong>Clinician:</strong> ${clinician}&nbsp;&nbsp;` : ''}
      ${date ? `<strong>Date:</strong> ${date}` : ''}
    </div>

  </div>`;

  // Build a custom output order: for each med how-it-works, immediately follow
  // with its corresponding side effects section (if enabled).
  const MED_IDS = ['dex','vyvanse','ritalinIR','ritalinLA','concerta','strattera','intuniv','catapres'];
  const seByMed = {};
  MED_IDS.forEach(id => { seByMed['s_meds_' + id] = 's_se_' + id; });

  // Build ordered list: SECTIONS in order, but skip s_se_* and instead inject
  // them right after their corresponding s_meds_* entry.
  const seSectionIds = new Set(MED_IDS.map(id => 's_se_' + id));
  const orderedSections = [];
  SECTIONS.forEach(s => {
    if (seSectionIds.has(s.id)) return; // skip — will be inserted inline
    orderedSections.push(s);
    const seId = seByMed[s.id];
    if (seId) {
      const seSec = SECTIONS.find(x => x.id === seId);
      if (seSec) orderedSections.push(seSec);
    }
  });

  let lastH1 = '';
  orderedSections.forEach(s => {
    if (!sectionOn(s.id)) return;
    let html = getSectionHTML(s.id);
    const h1Match = html.match(/^<div class="rich-h1">(.*?)<\/div>/);
    if (h1Match) {
      if (h1Match[1] === lastH1) {
        html = html.replace(/^<div class="rich-h1">.*?<\/div>\n?/, '');
      } else {
        lastH1 = h1Match[1];
      }
    }
    richHTML += html;
  });

  // Append plan tables if phases exist
  if (phases.length > 0) {
    richHTML += buildShortTableHTML();
    richHTML += '<div class="page-break" style="page-break-before:always;"></div>';
