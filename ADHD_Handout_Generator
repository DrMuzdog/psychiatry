// ==================== PLAN STATE ====================
let planMode = 'titration';
let phases = [];

function setPlanMode(mode, btn) {
  planMode = mode;
  document.querySelectorAll('.med-tab').forEach(b => b.classList.remove('active'));
  btn.classList.add('active');
  renderPhases();
  updateAddPhaseBtn();
}

function updateAddPhaseBtn() {
  const btn = document.getElementById('add-phase-btn');
  btn.textContent = planMode === 'titration' ? '+ Add Phase' : '+ Add Medication Group';
}

function resetPlan() {
  phases = [];
  renderPhases();
}

function loadPreset(key) {
  const p = PLAN_PRESETS[key];
  if (!p) return;
  // Switch mode
  planMode = p.mode;
  document.getElementById('mode-btn-titration').classList.toggle('active', p.mode === 'titration');
  document.getElementById('mode-btn-plan').classList.toggle('active', p.mode === 'plan');
  // Deep clone phases
  phases = JSON.parse(JSON.stringify(p.phases));
  renderPhases();
  updateAddPhaseBtn();
}

function addPhase() {
  const newPhase = {
    label: planMode === 'titration' ? 'Phase ' + (phases.length + 1) : 'Medications',
    duration: 7, unit: 'days', ongoing: false, note: '',
    meds: [],
    days: ['Mon','Tue','Wed','Thu','Fri','Sat','Sun'],
  };
  phases.push(newPhase);
  renderPhases();
  // Scroll to the new phase
  setTimeout(() => {
    const els = document.querySelectorAll('.vv-phase');
    if (els.length) els[els.length - 1].scrollIntoView({ behavior: 'smooth', block: 'nearest' });
  }, 50);
}

function removePhase(idx) {
  phases.splice(idx, 1);
  renderPhases();
}

function updatePhaseDays(pi) {
  const DOW_ALL = ['Mon','Tue','Wed','Thu','Fri','Sat','Sun'];
  const selected = DOW_ALL.filter(d => {
    const el = document.getElementById(`dow-${pi}-${d.toLowerCase()}`);
    return el && el.checked;
  });
  phases[pi].days = selected;
  // No need to re-render — just update state
}

// ==================== RENDER PHASES ====================
function renderPhases() {
  const container = document.getElementById('plan-phases');
  container.innerHTML = '';
  if (phases.length === 0) {
    container.innerHTML = `<div style="color:var(--grey);font-size:0.9em;padding:14px 0;font-style:italic;">No phases yet. Load an example or click Add Phase to start.</div>`;
    return;
  }
  phases.forEach((ph, pi) => {
    const div = document.createElement('div');
    div.className = 'vv-phase';
    div.style.marginBottom = '14px';
    div.innerHTML = renderPhaseHTML(ph, pi);
    container.appendChild(div);
  });
}

