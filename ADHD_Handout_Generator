function richToPlain(html) {
  const tmp = document.createElement('div');
  tmp.innerHTML = html;
  // Replace headings
  tmp.querySelectorAll('.rich-h1').forEach(el => { el.textContent = '\n\n=== ' + el.textContent.toUpperCase() + ' ===\n'; });
  tmp.querySelectorAll('.rich-h2').forEach(el => { el.textContent = '\n--- ' + el.textContent + ' ---\n'; });
  tmp.querySelectorAll('.rich-h3').forEach(el => { el.textContent = '\n' + el.textContent + '\n'; });
  tmp.querySelectorAll('li').forEach(el => { el.textContent = '  * ' + el.textContent + '\n'; });
  tmp.querySelectorAll('table').forEach(tbl => {
    let t = '\n';
    tbl.querySelectorAll('tr').forEach(tr => {
      const cells = [];
      tr.querySelectorAll('th,td').forEach(td => cells.push(td.textContent.trim().replace(/\s+/g,' ')));
      t += cells.join(' | ') + '\n';
    });
    tbl.textContent = t;
  });
  return tmp.textContent.replace(/\n{3,}/g, '\n\n').trim();
}

