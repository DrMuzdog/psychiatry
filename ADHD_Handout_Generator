function generateOutput() {
  const patientName = document.getElementById('patient-name').value;
  const clinician = document.getElementById('clinician-name').value;
  const date = document.getElementById('patient-date').value;

  let richHTML = '';
  richHTML += `<div style="margin-bottom:20px;padding-bottom:14px;border-bottom:2px solid var(--lightblue);">
    <h2 style="color:var(--blue);font-size:1.5em;margin-bottom:4px;">ADHD: What You Need to Know</h2>
