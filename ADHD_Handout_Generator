  const innerHtml = el.innerHTML;

  // Word-compatible wrapper: includes heading styles so bold/colour is preserved on paste
  const wordHtml = `<html xmlns:o="urn:schemas-microsoft-com:office:office" xmlns:w="urn:schemas-microsoft-com:office:word" xmlns="http://www.w3.org/TR/REC-html40"><head><meta charset="UTF-8"><style>body{font-family:Arial,sans-serif;font-size:11pt;line-height:1.4;} p{margin:0 0 6pt 0;} .rich-h1{font-family:Arial,sans-serif;font-size:13pt;font-weight:bold;color:#1a3a6b;margin:14pt 0 4pt;border-bottom:1pt solid #c8d8ee;padding-bottom:2pt;display:block;} .rich-h2{font-family:Arial,sans-serif;font-size:11pt;font-weight:bold;color:#2a5298;margin:10pt 0 3pt;display:block;} .rich-h3{font-family:Arial,sans-serif;font-size:10pt;font-weight:bold;color:#1a3a6b;margin:7pt 0 2pt;font-style:italic;display:block;} .rich-p{font-size:11pt;margin-bottom:5pt;} .rich-ul{margin:3pt 0 7pt 16pt;} .rich-ul li{margin-bottom:3pt;font-size:11pt;} .rich-cite{font-size:9pt;color:#666;font-style:italic;} table{border-collapse:collapse;width:auto;} th,td{border:1pt solid #999;padding:3pt 5pt;font-family:Arial,sans-serif;font-size:9pt;} </style></head><body>${innerHtml}</body></html>`;

  if (window.ClipboardItem) {
    const blob = new Blob([wordHtml], { type: 'text/html' });
    const item = new ClipboardItem({ 'text/html': blob });
    navigator.clipboard.write([item]).then(showToast).catch(() => {
      fallbackCopy(el);
    });
  } else {
    fallbackCopy(el);
  }
}

function fallbackCopy(el) {
  const range = document.createRange();
  range.selectNode(el);
  window.getSelection().removeAllRanges();
  window.getSelection().addRange(range);
  document.execCommand('copy');
  window.getSelection().removeAllRanges();
  showToast();
}

function showToast() {
  const t = document.getElementById('toast');
  t.classList.add('show');
  setTimeout(() => t.classList.remove('show'), 2000);
}

// ==================== PRINT REPORT ====================
function downloadPDF() {
  const tabMap = { rich: 'output-rich', tit: 'output-tit-only', long: 'output-long', script: 'output-script', plain: 'output-plain' };
  const contentEl = document.getElementById(tabMap[currentOutputTab] || 'output-rich');
  if (!contentEl) return;
  const isText = (currentOutputTab === 'script' || currentOutputTab === 'plain');
  const patName = document.getElementById('patient-name').value || '';
  const drName = (document.getElementById('clinician-name') ? document.getElementById('clinician-name').value : '') || '';
  const headerLeft = patName ? 'ADHD Guide \u2014 ' + patName + (drName ? ' | ' + drName : '') : 'ADHD Guide' + (drName ? ' | ' + drName : '');

  const bodyContent = isText
    ? `<pre style="font-family:monospace;font-size:9.5pt;white-space:pre-wrap;">${contentEl.textContent}</pre>`
    : contentEl.innerHTML;

  const pdfDoc = `<!DOCTYPE html><html lang="en"><head><meta charset="UTF-8">
<title>ADHD Guide${patName ? ' — ' + patName : ''}</title>
<style>
  @page { margin: 2cm 2.2cm 2.2cm 2.2cm; }
  * { box-sizing: border-box; }
  body { font-family: Arial, sans-serif; font-size: 11pt; line-height: 1.45; color: #222; background: white; margin: 0; padding: 0; }
  .pdf-header { font-size: 9pt; color: #555; border-bottom: 1pt solid #ccc; padding-bottom: 5pt; margin-bottom: 16pt; display: flex; justify-content: space-between; }
  .rich-h1 { font-size: 13pt; font-weight: bold; color: #1a3a6b; margin: 14pt 0 4pt; border-bottom: 1pt solid #c8d8ee; padding-bottom: 2pt; }
  .rich-h2 { font-size: 11pt; font-weight: bold; color: #2a5298; margin: 10pt 0 3pt; }
  .rich-h3 { font-size: 10pt; font-weight: bold; color: #1a3a6b; margin: 7pt 0 2pt; font-style: italic; }
  .rich-p { font-size: 11pt; margin-bottom: 5pt; }
  .rich-ul { margin: 3pt 0 7pt 16pt; }
  .rich-ul li { margin-bottom: 3pt; font-size: 11pt; }
  .rich-cite { font-size: 9pt; color: #666; font-style: italic; }
  table { border-collapse: collapse; width: auto; font-size: 9pt; }
  th, td { border: 1pt solid #999; padding: 3pt 5pt; }
  @media print {
    body { background: white !important; }
    .pdf-header { position: running(header); }
  }
</style>
</head><body>
<div class="pdf-header"><span>${headerLeft}</span><span id="pdf-date">${new Date().toLocaleDateString('en-AU',{day:'2-digit',month:'short',year:'numeric'})}</span></div>
${bodyContent}
</body></html>`;

  const w = window.open('', '_blank', 'width=900,height=750');
  if (!w) { alert('Please allow pop-ups for PDF generation.'); return; }
  w.document.write(pdfDoc);
  w.document.close();
  setTimeout(() => {
    w.focus();
    w.print(); // browser Save as PDF dialog
  }, 600);
}

function printReport() {
  const tabMap = { rich: 'output-rich', tit: 'output-tit-only', long: 'output-long', script: 'output-script', plain: 'output-plain' };
  const contentEl = document.getElementById(tabMap[currentOutputTab] || 'output-rich');
  if (!contentEl) return;
  const content = contentEl.innerHTML || contentEl.textContent;
  const isText = (currentOutputTab === 'script' || currentOutputTab === 'plain');

  // Collect all CSS from the page
  let styleText = '';
  document.querySelectorAll('style').forEach(s => { styleText += s.innerHTML + '\n'; });

  const bodyContent = isText
    ? `<pre style="font-family:monospace;font-size:0.87em;white-space:pre-wrap;padding:20px;">${contentEl.textContent}</pre>`
    : `<div style="padding:28px 40px;font-size:0.95em;line-height:1.7;">${content}</div>`;

  const printDoc = `<!DOCTYPE html><html lang="en"><head><meta charset="UTF-8">
<title>ADHD Guide</title>
<style>
${styleText}
@media print { .page-break { page-break-before: always; } body { background: white !important; } }
body { font-family: 'Segoe UI', Arial, sans-serif; background: white; color: #222; }
</style>
</head><body>
${bodyContent}
</body></html>`;

  const w = window.open('', '_blank', 'width=900,height=700');
  if (!w) { alert('Please allow pop-ups to use Print Report.'); return; }
  w.document.write(printDoc);
  w.document.close();
  setTimeout(() => { w.focus(); w.print(); }, 500);
}

