      <div class="med-pill-row" style="display:flex;flex-wrap:wrap;gap:6px;">
        ${Object.entries(MEDS).map(([k,m]) => `<button onclick="addMedDirectly(${pi},'${k}')" style="padding:5px 12px;border-radius:20px;border:1.5px solid var(--midblue);background:white;color:var(--midblue);font-size:0.83em;font-weight:600;cursor:pointer;" onmouseover="this.style.background='var(--lightblue)'" onmouseout="this.style.background='white'">+ ${m.name}</button>`).join('')}
      </div>
    </div>
    <div style="margin-top:10px;">
      <div class="vv-field">
        <label>Notes</label>
        <input type="text" value="${ph.note}" oninput="phases[${pi}].note=this.value" style="width:100%;" placeholder="e.g. Good tolerability required before proceeding">
      </div>
    </div>`;
}

function renderMedRow(med, pi, mi) {
  const medDef = MEDS[med.medId];
  if (!medDef) return '';
  const isMultiCap = medDef.multiCap;
  const isSingleCap = medDef.singleCap;
  const hasDoseOptions = !isMultiCap && !isSingleCap && medDef.doseOptions;

  // Timing chips: each dose entry
  let doseChips = med.doses.map((d, di) => renderDoseChip(d, pi, mi, di, medDef)).join('');

  // Strength selector (for single-cap meds)
  let strengthHTML = '';
  if (isSingleCap || isMultiCap) {
    const strOpts = medDef.strengths.map(s => `<option value="${s}" ${s===(med.strength||medDef.defaultStrength)?'selected':''}>${s} ${medDef.unit}</option>`).join('');
    if (!isMultiCap) {
      strengthHTML = `<div class="vv-field"><label>Strength</label>
        <select onchange="const s=parseInt(this.value);phases[${pi}].meds[${mi}].strength=s;phases[${pi}].meds[${mi}].doses.forEach(d=>d.strength=s);renderPhases();">${strOpts}</select></div>`;
    }
  }

  // For multi-cap (Vyvanse): show cap badges per dose slot
  // For others: show dose picker per timing slot

  let addTimingHTML = renderAddTimingRow(pi, mi, medDef);

  return `
    <div style="background:white;border:1.5px solid #c8d8ee;border-radius:7px;padding:12px 14px;margin-bottom:8px;position:relative;">
      <div style="display:flex;align-items:center;gap:10px;margin-bottom:8px;">
        <strong style="color:var(--blue);font-size:0.95em;">${medDef.name}</strong>
        ${medDef.mustSwallowWhole ? '<span style="font-size:0.75em;background:#FFF3CD;color:#7A4000;padding:2px 7px;border-radius:10px;">Swallow whole</span>' : ''}
        ${medDef.canSprinkle ? '<span style="font-size:0.75em;background:#E8F5E9;color:#2E7D32;padding:2px 7px;border-radius:10px;">Can sprinkle</span>' : ''}
        ${medDef.mustDxUnder18 ? '<span style="font-size:0.75em;background:#FCE4EC;color:#880E4F;padding:2px 7px;border-radius:10px;">Dx &lt;18 yrs</span>' : ''}
        <button onclick="removeMedFromPhase(${pi},${mi})" style="margin-left:auto;background:none;border:none;color:var(--red);cursor:pointer;font-size:1em;opacity:0.7;">&#x2715;</button>
      </div>
      ${strengthHTML}
      <div style="margin-top:8px;">
        <div style="font-size:0.78em;font-weight:600;color:var(--grey);text-transform:uppercase;letter-spacing:0.4px;margin-bottom:6px;">Dosing Schedule</div>
        <div id="dose-chips-${pi}-${mi}" style="display:flex;flex-direction:column;gap:6px;">${doseChips}</div>
        ${addTimingHTML}
      </div>
    </div>`;
}

function renderAddTimingRow(pi, mi, medDef) {
  const timings = ['morning','midday','afternoon','evening','5am','7am','8am','9am','10am','12pm','1pm','2pm','3pm','4pm','6pm','8pm','10pm','custom'];
  const tOpts = timings.map(t => `<option value="${t}">${t === 'custom' ? 'Custom time...' : t}</option>`).join('');
  return `<div style="display:flex;gap:8px;align-items:center;margin-top:8px;flex-wrap:wrap;">
    <select id="add-timing-sel-${pi}-${mi}" style="border:1.5px solid #c8d8ee;border-radius:5px;padding:5px 8px;font-size:0.87em;">${tOpts}</select>
    <button class="btn btn-outline" style="padding:4px 10px;font-size:0.83em;" onclick="addDoseToMed(${pi},${mi})">+ Add Dose Time</button>
  </div>`;
}

function renderDoseChip(dose, pi, mi, di, medDef) {
  const isMultiCap = medDef.multiCap;
  const isFreeText = medDef.freeTextDose;
  const hasDoseOpts = medDef.doseOptions && !isMultiCap && !isFreeText;
  let doseControl = '';

  if (isFreeText) {
    const val = dose.label || medDef.defaultDoseText || '';
    doseControl = `<input type="text" value="${val.replace(/"/g,'&quot;')}" placeholder="e.g. ¼ tab, 2½ tabs"
      style="border:1.5px solid #c8d8ee;border-radius:5px;padding:4px 8px;font-size:0.87em;width:100%;"
      onchange="phases[${pi}].meds[${mi}].doses[${di}].label=this.value;">`;
  } else if (isMultiCap) {
    // Vyvanse-style: cap badges
    const caps = dose.caps || [];
    const capsHTML = caps.map((c, ci) =>
      `<span class="cap-badge">${c} mg <button onclick="removeCapFromDose(${pi},${mi},${di},${ci})">&#x2715;</button></span>`
    ).join('');
    const capOpts = medDef.strengths.map(s => `<option value="${s}">${s} mg</option>`).join('');
    doseControl = `<div class="vv-caps" style="gap:4px;">${capsHTML}</div>
      <div class="add-cap-row" style="margin-top:4px;">
        <select id="capsel-${pi}-${mi}-${di}" style="border:1.5px solid #c8d8ee;border-radius:5px;padding:4px 7px;font-size:0.85em;">${capOpts}</select>
        <button class="btn btn-outline" style="padding:3px 9px;font-size:0.8em;" onclick="addCapToDose(${pi},${mi},${di})">+ Cap</button>
      </div>`;
    const total = caps.reduce((a, b) => a + b, 0);
    doseControl += `<div style="font-size:0.8em;color:var(--grey);margin-top:3px;">Total: ${total} mg</div>`;
  } else if (hasDoseOpts) {
    const opts = medDef.doseOptions.map(o =>
      `<option value="${o.qty}" data-label="${o.label}" ${o.qty === dose.qty ? 'selected' : ''}>${o.label}</option>`
    ).join('');
    doseControl = `<select style="border:1.5px solid #c8d8ee;border-radius:5px;padding:4px 8px;font-size:0.87em;"
      onchange="phases[${pi}].meds[${mi}].doses[${di}].qty=parseFloat(this.value);phases[${pi}].meds[${mi}].doses[${di}].label=this.options[this.selectedIndex].dataset.label;">
      ${opts}</select>`;
  } else {
    // Single cap strength-based
    const str = medDef.strengths[0];
    doseControl = `<span style="font-size:0.87em;color:var(--grey);">1 ${medDef.form} (${medDef.singleCap ? (dose.strength || medDef.defaultStrength) : str} ${medDef.unit})</span>`;
  }

  const timeLabel = dose.time || 'morning';
  return `
    <div style="display:flex;align-items:flex-start;gap:8px;background:var(--altrow);padding:6px 10px;border-radius:6px;">
      <div style="min-width:90px;">
        <div style="font-size:0.78em;font-weight:700;color:var(--midblue);text-transform:uppercase;">${timeLabel}</div>
        ${isMultiCap ? '' : `<input type="text" value="${timeLabel}" style="width:100%;border:1px solid #c8d8ee;border-radius:4px;padding:2px 5px;font-size:0.82em;margin-top:2px;"
          onchange="phases[${pi}].meds[${mi}].doses[${di}].time=this.value;" title="Edit timing">`}
      </div>
      <div style="flex:1;">${doseControl}</div>
      <button onclick="removeDoseFromMed(${pi},${mi},${di})" style="background:none;border:none;color:var(--red);cursor:pointer;font-size:0.95em;opacity:0.6;margin-top:2px;">&#x2715;</button>
    </div>`;
}

// ==================== MED/DOSE MUTATIONS ====================
function addMedDirectly(pi, medId) {
  addMedWithId(pi, medId);
}
function addMedToPhase(pi) {
  const medId = document.getElementById('add-med-sel-' + pi)?.value;
  if (!medId) return;
  addMedWithId(pi, medId);
}
function addMedWithId(pi, medId) {
  const medDef = MEDS[medId];
  const newMed = {
    medId,
    strength: medDef.defaultStrength,
    doses: [],
    caps: medDef.multiCap ? [medDef.defaultStrength] : [],
  };
  // Add a default morning dose
  if (medDef.multiCap) {
    newMed.doses.push({ time: 'morning', caps: [medDef.defaultStrength] });
  } else if (medDef.freeTextDose) {
    newMed.doses.push({ time: 'morning', qty: 1, label: medDef.defaultDoseText || '1 tab' });
  } else if (medDef.singleCap) {
    newMed.doses.push({ time: 'morning', qty: 1, label: `1 ${medDef.form} (${medDef.defaultStrength} ${medDef.unit})`, strength: medDef.defaultStrength });
  } else if (medDef.doseOptions) {
    newMed.doses.push({ time: 'morning', qty: medDef.doseOptions[1]?.qty || 1, label: medDef.doseOptions[1]?.label || '1 tab' });
  } else {
    newMed.doses.push({ time: 'morning', qty: 1, label: `1 ${medDef.form}` });
  }
  phases[pi].meds.push(newMed);
  renderPhases();
}

function removeMedFromPhase(pi, mi) {
  phases[pi].meds.splice(mi, 1);
  renderPhases();
}

function addDoseToMed(pi, mi) {
  const sel = document.getElementById(`add-timing-sel-${pi}-${mi}`);
  let time = sel.value;
  if (time === 'custom') {
    time = prompt('Enter custom time (e.g. "5am", "9:30am"):');
    if (!time) return;
  }
  const medDef = MEDS[phases[pi].meds[mi].medId];
  let newDose;
  if (medDef.multiCap) {
    newDose = { time, caps: [medDef.defaultStrength] };
  } else if (medDef.freeTextDose) {
    newDose = { time, qty: 1, label: medDef.defaultDoseText || '1 tab' };
  } else if (medDef.singleCap) {
    newDose = { time, qty: 1, label: `1 ${medDef.form} (${phases[pi].meds[mi].strength || medDef.defaultStrength} ${medDef.unit})`, strength: phases[pi].meds[mi].strength || medDef.defaultStrength };
  } else if (medDef.doseOptions) {
    newDose = { time, qty: medDef.doseOptions[0].qty, label: medDef.doseOptions[0].label };
  } else {
    newDose = { time, qty: 1, label: `1 ${medDef.form}` };
  }
  phases[pi].meds[mi].doses.push(newDose);
  renderPhases();
}

function removeDoseFromMed(pi, mi, di) {
  phases[pi].meds[mi].doses.splice(di, 1);
  renderPhases();
}

function addCapToDose(pi, mi, di) {
  const sel = document.getElementById(`capsel-${pi}-${mi}-${di}`);
  const val = parseInt(sel.value);
  phases[pi].meds[mi].doses[di].caps.push(val);
  phases[pi].meds[mi].doses[di].caps.sort((a, b) => b - a);
  renderPhases();
}

function removeCapFromDose(pi, mi, di, ci) {
  phases[pi].meds[mi].doses[di].caps.splice(ci, 1);
  renderPhases();
}

// ==================== OUTPUT GENERATION ====================
// Helper: get dose display string for a dose object
function getDoseDisplay(dose, medDef) {
  if (!dose) return '--';
  if (medDef.multiCap) {
    const caps = dose.caps || [];
    if (!caps.length) return '--';
    return caps.map(c => c + ' mg').join(' + ') + ' (' + caps.reduce((a,b)=>a+b,0) + ' mg total)';
  }
  if (dose.label) return dose.label;
  return dose.qty ? dose.qty + ' ' + medDef.form : '--';
}

// Helper: describe all meds in a phase for inline text
function describePhaseMeds(ph) {
  return ph.meds.map(med => {
    const def = MEDS[med.medId];
    if (!def) return '';
    const doseStr = med.doses.map(d => {
      const dText = getDoseDisplay(d, def);
      return `${d.time}: ${dText}`;
    }).join(', ');
    return `${def.name} — ${doseStr}`;
  }).join('; ');
}

// Build short plan table (one row per phase)
function buildShortTableHTML() {
  if (!phases.length) return '<p style="color:var(--grey);">No plan configured.</p>';
  const isTitration = planMode === 'titration';
  const title = isTitration ? 'Titration Protocol' : 'Medication Plan';

  // Collect all unique timing labels
  const allTimes = new Set();
  phases.forEach(ph => ph.meds.forEach(med => med.doses.forEach(d => allTimes.add(d.time))));
  const timeList = [...allTimes];

  // For short table: rows = phases, columns = (phase label, duration, each med per timing, notes)
  let h = `<div class="rich-h1">${title}</div>`;
  if (isTitration) {
    h += `<div style="background:#FFF3CD;border-left:4px solid #E36C09;border-radius:6px;padding:10px 14px;margin-bottom:14px;font-size:0.92em;">
      <strong style="color:#7A4000;">&#128197; Prescription reminder:</strong> <span style="color:#5C3000;">You can only obtain your next prescription a minimum of <strong>20 days</strong> after your current one was dispensed.</span>
    </div>`;
  }

  const STH = 'style="border:1pt solid #b0c4de;padding:3pt 5pt;font-family:Arial,sans-serif;font-size:9pt;background:#d6e4f7;color:#1a3a6b;font-weight:bold;text-align:left;"';
  const STD = 'style="border:1pt solid #c8d8ee;padding:3pt 5pt;font-family:Arial,sans-serif;font-size:9pt;text-align:left;vertical-align:top;"';
  const STD_PHASE = 'style="border:1pt solid #1a3a6b;padding:3pt 5pt;font-family:Arial,sans-serif;font-size:9pt;background:#1a3a6b;color:white;font-weight:bold;white-space:nowrap;"';

  // Only show Notes column if at least one phase has a note
  const hasNotes = phases.some(ph => ph.note && ph.note.trim());

  h += `<table style="border-collapse:collapse;width:auto;max-width:100%;font-family:Arial,sans-serif;font-size:9pt;"><thead><tr>`;
  if (isTitration) h += `<th ${STH}>Phase</th><th ${STH}>Duration</th>`;
  else h += `<th ${STH}>Medications</th>`;
  h += `<th ${STH}>Dosing</th>`;
  if (isTitration || hasNotes) h += `<th ${STH}>Notes</th>`;
  h += `</tr></thead><tbody>`;

  phases.forEach((ph, pi) => {
    const durationText = ph.ongoing ? 'Ongoing / until next review' :
      ph.duration ? `${ph.duration} ${ph.unit}` : '';
    const medLines = ph.meds.map(med => {
      const def = MEDS[med.medId];
      if (!def) return '';
      const dStr = med.doses.map(d => {
        const dText = getDoseDisplay(d, def);
        return `<strong>${d.time}:</strong> ${dText}`;
      }).join('<br>');
      return `<div style="margin-bottom:5pt;font-family:Arial,sans-serif;"><em>${def.name}</em><br>${dStr}</div>`;
    }).join('');
    // For plan mode, add days note if not all 7
    let daysNote = '';
    if (!isTitration) {
      const phDays = ph.days || ['Mon','Tue','Wed','Thu','Fri','Sat','Sun'];
      if (phDays.length < 7) {
        daysNote = `<div style="font-size:9pt;color:#666;margin-top:3pt;">(${phDays.join('\u2013')})</div>`;
      }
    }
    h += `<tr>`;
    if (isTitration) {
      h += `<td ${STD_PHASE}>${ph.label}</td>`;
      h += `<td ${STD} style="border:1pt solid #c8d8ee;padding:3pt 5pt;font-family:Arial,sans-serif;font-size:9pt;text-align:left;vertical-align:top;white-space:nowrap;">${durationText}</td>`;
    } else {
      h += `<td ${STD} style="border:1pt solid #c8d8ee;padding:3pt 5pt;font-family:Arial,sans-serif;font-size:9pt;text-align:left;vertical-align:top;font-weight:700;color:#1a3a6b;">${ph.label}</td>`;
    }
    h += `<td ${STD}>${medLines}${daysNote}</td>`;
    if (isTitration || hasNotes) h += `<td ${STD} style="border:1pt solid #c8d8ee;padding:3pt 5pt;font-family:Arial,sans-serif;font-size:9pt;text-align:left;vertical-align:top;">${ph.note||''}</td>`;
    h += `</tr>`;
  });
  h += `</tbody></table>`;

  // Medication info footnotes
  const usedMeds = new Set();
  phases.forEach(ph => ph.meds.forEach(m => usedMeds.add(m.medId)));
  if (usedMeds.size) {
    h += `<div style="margin-top:16px;">`;
    h += `<div class="rich-h2">Medication Notes</div>`;
    [...usedMeds].forEach(id => {
      const def = MEDS[id];
      if (!def) return;
      const badges = [];
      if (def.gluten) badges.push('<span style="background:#FFF3CD;color:#7A4000;padding:1px 6px;border-radius:8px;font-size:0.8em;">contains gluten</span>');
      if (def.lactose) badges.push('<span style="background:#FFF3CD;color:#7A4000;padding:1px 6px;border-radius:8px;font-size:0.8em;">contains lactose</span>');
      if (def.gelatin) badges.push('<span style="background:#FFF3CD;color:#7A4000;padding:1px 6px;border-radius:8px;font-size:0.8em;">contains gelatin</span>');
      if (def.mustSwallowWhole) badges.push('<span style="background:#E3F2FD;color:#1565C0;padding:1px 6px;border-radius:8px;font-size:0.8em;">swallow whole</span>');
      if (def.canSprinkle) badges.push('<span style="background:#E8F5E9;color:#2E7D32;padding:1px 6px;border-radius:8px;font-size:0.8em;">can sprinkle</span>');
      // Side effect summary per medication
      const seFrag = getSideEffectSummary(id);
      h += `<p class="rich-p"><strong>${def.brandName}:</strong> Onset ${def.onset}. Duration ${def.duration}. ${def.notes} ${badges.join(' ')}</p>`;
      if (seFrag) h += `<p class="rich-p" style="font-size:0.87em;color:var(--grey);margin-top:-6px;">${seFrag}</p>`;
    });
    h += `</div>`;
  }
  return h;
}

function getSideEffectSummary(medId) {
  const summaries = {
    dex: 'Common side effects: dry mouth, reduced appetite, insomnia, jitteriness, headache, irritability. Interactions: avoid with acidic drinks at same time; discuss with doctor before adding decongestants or antidepressants.',
    vyvanse: 'Common side effects: dry mouth, reduced appetite, insomnia, jitteriness, headache, irritability. Interactions: avoid acidic drinks at same time; discuss with doctor before adding decongestants or antidepressants.',
    ritalinIR: 'Common side effects: dry mouth, reduced appetite, insomnia, jitteriness, headache, irritability. Interactions: avoid acidic drinks at same time; discuss with doctor before adding decongestants or antidepressants.',
    ritalinLA: 'Common side effects: dry mouth, reduced appetite, insomnia, jitteriness, headache, irritability. Interactions: avoid acidic drinks at same time; discuss with doctor before adding decongestants or antidepressants.',
    concerta: 'Common side effects: dry mouth, reduced appetite, insomnia, jitteriness, headache, irritability. Interactions: avoid acidic drinks at same time; discuss with doctor before adding decongestants or antidepressants.',
    strattera: 'Common side effects: constipation, dry mouth, nausea, dizziness, mood swings, insomnia. Takes 4–12 weeks for full effect. Avoid with fluoxetine, paroxetine, or bupropion.',
