<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>ADHD Patient Guide Generator</title>
<style>
  :root {
    --blue: #1F497D; --midblue: #2E74B5; --lightblue: #D9E2F3;
    --altrow: #F4F7FC; --grey: #595959; --lightgrey: #AAAAAA;
    --red: #C00000; --green: #375623; --amber: #E36C09;
    --bg: #F7F9FC; --white: #ffffff;
    --radius: 8px; --shadow: 0 2px 8px rgba(0,0,0,0.10);
  }
  * { box-sizing: border-box; margin: 0; padding: 0; }
  button, [role="button"], .card-header, .output-tab, .med-tab, .preset-btn {
    -webkit-tap-highlight-color: rgba(0,0,0,0.1);
    touch-action: manipulation;
  }
  body { font-family: 'Segoe UI', Arial, sans-serif; background: var(--bg); color: #222; font-size: 15px; }
  header { background: var(--blue); color: white; padding: 22px 32px 16px; }
  header h1 { font-size: 1.7em; font-weight: 700; letter-spacing: -0.5px; }
  header p { margin-top: 4px; opacity: 0.85; font-size: 0.95em; }
  .container { max-width: 1100px; margin: 0 auto; padding: 28px 20px 60px; }
  .card { background: var(--white); border-radius: var(--radius); box-shadow: var(--shadow); margin-bottom: 28px; overflow: hidden; }
  .card-header { background: var(--lightblue); padding: 13px 20px; font-weight: 700; font-size: 1.05em; color: var(--blue); display: flex; align-items: center; gap: 10px; cursor: pointer; user-select: none; }
  .card-header .toggle { margin-left: auto; font-size: 0.85em; opacity: 0.7; transition: transform 0.2s; }
  .card-body { padding: 18px 20px; }
  .card-body.collapsed { display: none; }

  /* Section checkboxes */
  .section-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(260px, 1fr)); gap: 8px; }
  .section-item { display: flex; align-items: flex-start; gap: 8px; padding: 7px 10px; border-radius: 6px; background: var(--altrow); }
  .section-item input[type=checkbox] { margin-top: 2px; accent-color: var(--midblue); width: 16px; height: 16px; flex-shrink: 0; }
  .section-item label { font-size: 0.93em; cursor: pointer; line-height: 1.4; }
  .check-all-row { display: flex; gap: 10px; margin-bottom: 12px; }

  /* Medication selector */
  .med-tabs { display: flex; gap: 0; margin-bottom: 18px; border-radius: var(--radius); overflow: hidden; border: 1.5px solid var(--midblue); width: fit-content; }
  .med-tab { padding: 9px 22px; cursor: pointer; font-weight: 600; font-size: 0.93em; background: white; color: var(--midblue); border: none; transition: background 0.15s, color 0.15s; }
  .med-tab.active { background: var(--midblue); color: white; }
  .med-tab:not(:last-child) { border-right: 1.5px solid var(--midblue); }
  .med-panel { display: none; }
  .med-panel.active { display: block; }

  /* IR Table */
  .ir-table-wrap { overflow-x: auto; }
  table.tit { border-collapse: collapse; width: 100%; font-size: 0.9em; }
  table.tit th { background: var(--lightblue); color: var(--blue); padding: 8px 10px; text-align: center; font-weight: 700; border: 1px solid #c8d8ee; }
  table.tit th.left { text-align: left; }
  table.tit td { padding: 6px 8px; border: 1px solid #dde6f2; text-align: center; vertical-align: middle; }
  table.tit tr:nth-child(even) td { background: var(--altrow); }
  table.tit td.day-cell { font-weight: 600; color: var(--blue); text-align: center; width: 60px; }
  table.tit td.comment-cell input { width: 100%; border: 1px solid #ccc; border-radius: 4px; padding: 3px 6px; font-size: 0.88em; }
  .dose-cell { min-width: 110px; }
  .dose-options { display: flex; flex-direction: column; gap: 3px; align-items: flex-start; }
  .dose-options label { display: flex; align-items: center; gap: 5px; font-size: 0.87em; cursor: pointer; white-space: nowrap; }
  .dose-options input[type=radio] { accent-color: var(--midblue); }
  .phase-header td { background: var(--blue) !important; color: white !important; font-weight: 700; text-align: left; padding: 6px 10px; font-size: 0.88em; letter-spacing: 0.3px; }

  /* Vyvanse builder */
  .vv-builder { display: flex; flex-direction: column; gap: 14px; }
  .vv-phase { background: var(--altrow); border-radius: 8px; padding: 14px 16px; border-left: 4px solid var(--midblue); position: relative; }
  .vv-phase-header { display: flex; align-items: center; gap: 10px; margin-bottom: 10px; }
  .vv-phase-title { font-weight: 700; color: var(--blue); font-size: 0.97em; }
  .vv-phase-remove { margin-left: auto; background: none; border: none; color: var(--red); cursor: pointer; font-size: 1.1em; opacity: 0.7; }
  .vv-phase-remove:hover { opacity: 1; }
  .vv-row { display: flex; flex-wrap: wrap; gap: 12px; align-items: center; }
  .vv-field { display: flex; flex-direction: column; gap: 4px; }
  .vv-field label { font-size: 0.8em; font-weight: 600; color: var(--grey); text-transform: uppercase; letter-spacing: 0.4px; }
  .vv-field select, .vv-field input[type=number], .vv-field input[type=text] {
    border: 1.5px solid #c8d8ee; border-radius: 5px; padding: 6px 10px; font-size: 0.93em; background: white; color: #222; min-width: 80px;
  }
  .vv-caps { display: flex; gap: 6px; flex-wrap: wrap; align-items: center; }
  .cap-badge { display: inline-flex; align-items: center; gap: 5px; background: var(--midblue); color: white; border-radius: 20px; padding: 4px 12px; font-size: 0.85em; font-weight: 600; }
  .cap-badge button { background: none; border: none; color: white; cursor: pointer; font-size: 1em; line-height: 1; padding: 0 0 0 4px; opacity: 0.8; }
  .cap-badge button:hover { opacity: 1; }
  .add-cap-row { display: flex; gap: 8px; align-items: center; }
  .add-cap-row select { border: 1.5px solid #c8d8ee; border-radius: 5px; padding: 5px 8px; font-size: 0.9em; }
  .add-phase-btn { display: flex; align-items: center; gap: 8px; background: none; border: 2px dashed var(--midblue); color: var(--midblue); border-radius: 8px; padding: 10px 18px; font-weight: 600; cursor: pointer; width: 100%; justify-content: center; font-size: 0.95em; margin-top: 4px; transition: background 0.15s; }
  .add-phase-btn:hover { background: var(--lightblue); }
  .vv-note { font-size: 0.83em; color: var(--grey); margin-top: 6px; }

  /* Buttons */
  .btn { display: inline-flex; align-items: center; gap: 7px; padding: 10px 20px; border-radius: 6px; font-weight: 700; font-size: 0.93em; cursor: pointer; border: none; transition: opacity 0.15s, background 0.15s; }
  .btn-primary { background: var(--blue); color: white; }
  .btn-secondary { background: var(--midblue); color: white; }
  .btn-outline { background: white; color: var(--blue); border: 2px solid var(--blue); }
  .btn-green { background: var(--green); color: white; }
  .preset-btn { font-size: 0.78em; padding: 4px 10px; border-radius: 12px; border: 1.5px solid var(--midblue); background: #f0f5ff; color: var(--midblue); cursor: pointer; font-weight: 600; transition: background 0.15s, color 0.15s; white-space: nowrap; }
  .preset-btn.active { background: var(--midblue); color: white; border-color: var(--blue); }
  .preset-btn:hover { background: var(--midblue); color: white; }
  .btn:hover { opacity: 0.88; }
  .btn-row { display: flex; flex-wrap: wrap; gap: 10px; margin-top: 18px; }

  /* Output */
  #output-area { display: none; }
  #output-area.visible { display: block; }
  .output-card { background: white; border-radius: var(--radius); box-shadow: var(--shadow); overflow: hidden; }
  .output-tabs { display: flex; border-bottom: 2px solid var(--lightblue); }
  .output-tab { padding: 10px 22px; cursor: pointer; font-weight: 600; font-size: 0.92em; color: var(--grey); border: none; background: none; }
  .output-tab.active { color: var(--blue); border-bottom: 3px solid var(--blue); margin-bottom: -2px; }
  #output-rich { padding: 20px 28px; font-size: 0.92em; line-height: 1.4; }
  #output-plain { padding: 20px; font-family: monospace; font-size: 0.87em; white-space: pre-wrap; background: #f8f8f8; min-height: 200px; }
  #output-tit-only { padding: 28px 32px; overflow-x: auto; }
  .copy-btn-row { display: flex; gap: 10px; padding: 12px 20px; background: var(--altrow); border-top: 1px solid var(--lightblue); flex-wrap: wrap; }

  /* Rich output styles — 11pt body, compact */
  .rich-h1 { font-size: 1.15em; font-weight: 800; color: var(--blue); margin: 16px 0 4px; border-bottom: 2px solid var(--lightblue); padding-bottom: 3px; }
  .rich-h2 { font-size: 1.0em; font-weight: 700; color: var(--midblue); margin: 12px 0 3px; }
  .rich-h3 { font-size: 0.93em; font-weight: 700; color: var(--blue); margin: 8px 0 3px; font-style: italic; }
  .rich-p { margin-bottom: 6px; font-size: 0.92em; line-height: 1.4; }
  .rich-ul { margin: 4px 0 8px 16px; }
  .rich-ul li { margin-bottom: 3px; line-height: 1.4; font-size: 0.92em; }
  .rich-cite { font-size: 0.76em; color: var(--grey); font-style: italic; margin-bottom: 6px; }
  .rich-warn { color: var(--red); font-weight: 600; }
  .rich-tit { border-collapse: collapse; width: 100%; font-size: 0.85em; margin: 8px 0; }
  .rich-tit th { background: var(--lightblue); color: var(--blue); padding: 5px 8px; text-align: center; border: 1px solid #c8d8ee; font-weight: 700; }
  .rich-tit td { padding: 4px 7px; border: 1px solid #dde6f2; text-align: center; vertical-align: middle; }
  .rich-tit tr:nth-child(even) td { background: var(--altrow); }
  .rich-tit td.phase-row { background: var(--blue) !important; color: white !important; font-weight: 700; text-align: left; }

  /* Mobile responsiveness */
  @media (max-width: 600px) {
    header { padding: 16px 16px 12px; }
    header h1 { font-size: 1.3em; }
    .container { padding: 14px 10px 40px; }
    .card-body { padding: 12px 12px; }
    .card-header { padding: 14px 14px; font-size: 0.98em; min-height: 48px; }
    .btn { min-height: 44px; font-size: 0.95em; }
    .preset-btn { min-height: 36px; font-size: 0.82em; padding: 6px 12px; }
    .output-tab { min-height: 40px; }
    .med-tab { min-height: 40px; }
    .vv-row { flex-direction: column; gap: 8px; }
    .vv-field { width: 100%; }
    .vv-field select, .vv-field input[type=number], .vv-field input[type=text] { width: 100%; }
    .med-tabs { width: 100%; }
    .med-tab { flex: 1; padding: 9px 8px; font-size: 0.85em; }
    .btn-row { flex-direction: column; }
    .btn-row .btn { width: 100%; justify-content: center; }
    .output-tabs { flex-wrap: wrap; }
    .output-tab { padding: 8px 12px; font-size: 0.82em; }
    #output-rich, #output-tit-only { padding: 16px 12px; }
    .rich-tit { font-size: 0.78em; }
    .section-grid { grid-template-columns: 1fr; }
    .patient-name-row { flex-direction: column; }
    .patient-name-row input { min-width: unset; width: 100%; }
    .add-phase-btn { font-size: 0.88em; padding: 10px 12px; }
    .med-pill-row { flex-wrap: wrap; }
  }

  @media print {
    .no-print { display: none !important; }
    body { background: white; }
    .card { box-shadow: none; }
  }

  .patient-name-row { display: flex; gap: 14px; flex-wrap: wrap; margin-bottom: 14px; }
  .patient-name-row .field { display: flex; flex-direction: column; gap: 4px; }
  .patient-name-row label { font-size: 0.82em; font-weight: 600; color: var(--grey); text-transform: uppercase; }
  .patient-name-row input { border: 1.5px solid #c8d8ee; border-radius: 5px; padding: 7px 12px; font-size: 0.95em; min-width: 200px; }
  .toast { position: fixed; bottom: 24px; right: 24px; background: var(--green); color: white; padding: 12px 22px; border-radius: 8px; font-weight: 700; font-size: 0.95em; box-shadow: var(--shadow); opacity: 0; transition: opacity 0.3s; pointer-events: none; z-index: 999; }
  .toast.show { opacity: 1; }
</style>
</head>
<body>
<header>
  <h1>ADHD Patient Guide Generator</h1>
  <p>Build a personalised patient handout with titration schedule</p>
</header>
<div class="container">

<!-- Patient Details -->
<div class="card">
  <div class="card-header" role="button" onclick="toggleCard(this)">Patient Details <span class="toggle">&#9650;</span></div>
  <div class="card-body">
    <div class="patient-name-row">
      <div class="field"><label>Patient Name</label><input type="text" id="patient-name" placeholder="e.g. Jane Smith"></div>
      <div class="field"><label>Date</label><input type="date" id="patient-date"></div>
      <div class="field"><label>Clinician</label><input type="text" id="clinician-name" placeholder="e.g. Dr Smith"></div>
    </div>
  </div>
</div>

<!-- Section Selector -->
<div class="card">
  <div class="card-header" role="button" onclick="toggleCard(this)">Education <span class="toggle">&#9650;</span></div>
  <div class="card-body">
    <div class="check-all-row">
      <button class="btn btn-outline" onclick="setAllSections(false)">&#10003; Select All</button>
      <button class="btn btn-outline" onclick="setAllSections(true)">&#10005; Exclude All</button>
    </div>
    <div style="margin:10px 0 4px;font-size:0.78em;font-weight:700;color:var(--grey);text-transform:uppercase;letter-spacing:0.5px;">Quick Select</div>
    <div id="preset-btn-row" style="display:flex;flex-wrap:wrap;gap:6px;margin-bottom:12px;">
      <button class="preset-btn" data-preset="brief"       onclick="togglePreset('brief',this)">+ Brief Explainer</button>
      <button class="preset-btn" data-preset="detailed"    onclick="togglePreset('detailed',this)">+ Detailed Explainer</button>
      <button class="preset-btn" data-preset="therapy"     onclick="togglePreset('therapy',this)">+ Therapy</button>
      <button class="preset-btn" data-preset="selfhelp"    onclick="togglePreset('selfhelp',this)">+ Self-Help</button>
      <button class="preset-btn" data-preset="comms"       onclick="togglePreset('comms',this)">+ Communication</button>
      <button class="preset-btn" data-preset="disability"  onclick="togglePreset('disability',this)">+ Disability Support</button>
      <button class="preset-btn" data-preset="dex"         onclick="togglePreset('dex',this)">+ Dexamphetamine</button>
      <button class="preset-btn" data-preset="vyvanse"     onclick="togglePreset('vyvanse',this)">+ Vyvanse</button>
      <button class="preset-btn" data-preset="methylph"    onclick="togglePreset('methylph',this)">+ Methylphenidate</button>
      <button class="preset-btn" data-preset="strattera"   onclick="togglePreset('strattera',this)">+ Strattera</button>
      <button class="preset-btn" data-preset="intuniv"     onclick="togglePreset('intuniv',this)">+ Intuniv</button>
      <button class="preset-btn" data-preset="catapres"    onclick="togglePreset('catapres',this)">+ Catapres</button>
    </div>
    <div id="section-bubbles"></div>
  </div>
</div>

<!-- Medication Plan Builder -->
<div class="card">
  <div class="card-header" role="button" onclick="toggleCard(this)">Medication Plan <span class="toggle">&#9650;</span></div>
  <div class="card-body">

    <!-- Top control row: mode + presets -->
    <div style="display:flex;flex-wrap:wrap;gap:14px;align-items:flex-end;margin-bottom:20px;">
      <div class="vv-field">
        <label>Plan Type</label>
        <div class="med-tabs" style="margin-bottom:0;">
          <button class="med-tab active" id="mode-btn-titration" onclick="setPlanMode('titration',this)">Titration Protocol</button>
          <button class="med-tab" id="mode-btn-plan" onclick="setPlanMode('plan',this)">Medication Plan</button>
        </div>
      </div>
      <div class="vv-field">
        <label>Load Example</label>
        <div style="display:flex;gap:6px;flex-wrap:wrap;">
          <button class="btn btn-outline" style="padding:6px 12px;font-size:0.83em;" onclick="loadPreset('dexTitration')">Dex IR Titration</button>
          <button class="btn btn-outline" style="padding:6px 12px;font-size:0.83em;" onclick="loadPreset('ritalinTitration')">Ritalin IR Titration</button>
          <button class="btn btn-outline" style="padding:6px 12px;font-size:0.83em;" onclick="loadPreset('vyvanseTitration')">Vyvanse Titration</button>
          <button class="btn btn-outline" style="padding:6px 12px;font-size:0.83em;color:var(--red);border-color:var(--red);" onclick="resetPlan()">&#10005; Reset</button>
        </div>
      </div>
    </div>

    <!-- Phase builder -->
    <div id="plan-phases"></div>

    <button class="add-phase-btn" id="add-phase-btn" onclick="addPhase()">+ Add Phase</button>

  </div>
</div>

<!-- Generate -->
<div class="card no-print">
  <div class="card-header" role="button" onclick="toggleCard(this)">Generate Output <span class="toggle">&#9650;</span></div>
  <div class="card-body">
    <p style="font-size:0.9em;color:var(--grey);margin-bottom:12px;">Choose what to generate. Use the output tabs to switch views after generating.</p>
    <label style="display:flex;align-items:center;gap:8px;margin-bottom:14px;font-size:0.9em;cursor:pointer;">
      <input type="checkbox" id="show-tick-col" checked style="width:15px;height:15px;accent-color:var(--midblue);">
      Include tick-off checkbox column in day-by-day table
    </label>
    <div class="btn-row">
      <button class="btn btn-primary" onclick="generateOutput()">&#9654; Generate</button>
    </div>
  </div>
</div>

<!-- Output Area -->
<div id="output-area">
  <div class="card output-card">
    <div class="output-tabs">
      <button class="output-tab active" onclick="switchOutputTab('rich',this)">Full Guide</button>
      <button class="output-tab" onclick="switchOutputTab('tit',this)">Plan (short)</button>
      <button class="output-tab" onclick="switchOutputTab('long',this)">Plan (day-by-day)</button>
      <button class="output-tab" onclick="switchOutputTab('script',this)">Script Text</button>
      <button class="output-tab" onclick="switchOutputTab('plain',this)">Plain Text</button>
    </div>
    <div id="output-rich"></div>
    <div id="output-tit-only" style="display:none;"></div>
    <div id="output-long" style="display:none;padding:20px 28px;"></div>
    <div id="output-script" style="display:none;padding:20px;font-family:monospace;font-size:0.9em;white-space:pre-wrap;background:#f8f8f8;"></div>
    <div id="output-plain" style="display:none;"></div>
    <div class="copy-btn-row no-print">
      <button class="btn btn-outline" onclick="copyOutput()">&#128203; Copy (current tab)</button>
      <button class="btn btn-outline" onclick="downloadWordDoc()">&#128462; Download .doc</button>
      <button class="btn btn-outline" onclick="downloadPDF()">&#128196; Download PDF</button>
      <button class="btn btn-green" onclick="printReport()">&#128424; Print Report</button>
    </div>
  </div>
</div>

</div>
<div class="toast" id="toast">Copied!</div>

<script>
// ==================== SECTION DATA ====================
const SECTIONS = [
  { id:'s_what',    label:'What Is ADHD?' },
  { id:'s_brain',   label:'What Is Happening in the Brain' },
  { id:'s_core',    label:'Core Symptoms' },
  { id:'s_down',    label:'What Else Does It Generate?' },
  { id:'s_impact',  label:'The Real-World Impact (with stats)' },
  { id:'s_treat',   label:'Treatment Is Lifesaving' },
  { id:'s_feels',   label:'What Treatment Actually Feels Like' },
  { id:'s_meds_dex',       label:'Medication: Dexamphetamine' },
  { id:'s_meds_vyvanse',    label:'Medication: Vyvanse' },
  { id:'s_meds_ritalinIR',  label:'Medication: Ritalin IR / Artige' },
  { id:'s_meds_ritalinLA',  label:'Medication: Ritalin LA' },
  { id:'s_meds_concerta',   label:'Medication: Concerta' },
  { id:'s_meds_strattera',  label:'Medication: Strattera' },
  { id:'s_meds_intuniv',    label:'Medication: Intuniv' },
  { id:'s_meds_catapres',   label:'Medication: Catapres' },
  { id:'s_monitor', label:'What to Monitor During Titration' },
  { id:'s_safety',  label:'Important Safety Considerations' },
  { id:'s_myths',   label:'Myths — What the Evidence Says' },
  { id:'s_faq',     label:'Commonly Asked Questions' },
  // Optional psychoeducation additions
  { id:'s_supports', label:'Accessing Supports &amp; Services', excludedByDefault: true },
  { id:'s_workplace', label:'Workplace Adjustments', excludedByDefault: true },
  // Optional grief section (excluded by default — clinician discretion)
  { id:'s_grief',   label:'Grief After Late Diagnosis', excludedByDefault: true },
  // Treatment resources
  { id:'s_resources_aus', label:'Australian ADHD Websites' },
  { id:'s_resources_meds', label:'Medication Information Websites' },
  { id:'s_nonpharm_cbt',       label:'Non-Pharm: CBT' },
  { id:'s_nonpharm_coaching',  label:'Non-Pharm: ADHD Coaching' },
  { id:'s_nonpharm_mindful',   label:'Non-Pharm: Mindfulness' },
  { id:'s_nonpharm_dbt',       label:'Non-Pharm: DBT' },
  { id:'s_nonpharm_exercise',  label:'Non-Pharm: Exercise' },
  { id:'s_nonpharm_ot',        label:'Non-Pharm: Occupational Therapy' },
  { id:'s_sh_braindump',     label:'Self-Help: Brain Dump' },
  { id:'s_sh_phone',         label:'Self-Help: Phone &amp; Social Media' },
  { id:'s_sh_timeblock',     label:'Self-Help: Time Blocking' },
  { id:'s_sh_bodydouble',    label:'Self-Help: Body Doubling' },
  { id:'s_sh_ifthen',        label:'Self-Help: If-Then Planning' },
  { id:'s_sh_decisions',     label:'Self-Help: Decision Fatigue' },
  { id:'s_sh_reward',        label:'Self-Help: Reward Pairing' },
  { id:'s_sh_bingeeating',   label:'Self-Help: Binge Eating' },
  { id:'s_sh_emotional',     label:'Self-Help: Emotional Dysregulation' },
  { id:'s_sh_kids',          label:'Self-Help: Difficulty With Kids' },
  { id:'s_sh_partner',       label:'Self-Help: Difficulty With Partner' },
  { id:'s_sh_commsadult',    label:'Self-Help: Communicating With ADHD Adult' },
  { id:'s_sh_commschild',    label:'Self-Help: Talking With ADHD Child' },
  { id:'s_sh_exercise',      label:'Self-Help: Exercise for ADHD' },
  { id:'s_sh_sleep',         label:'Self-Help: Managing Sleep' },
  { id:'s_se_dex',       label:'Side Effects: Dexamphetamine' },
  { id:'s_se_vyvanse',   label:'Side Effects: Vyvanse' },
  { id:'s_se_ritalinIR', label:'Side Effects: Ritalin IR / Artige' },
  { id:'s_se_ritalinLA', label:'Side Effects: Ritalin LA' },
  { id:'s_se_concerta',  label:'Side Effects: Concerta' },
  { id:'s_se_strattera', label:'Side Effects: Strattera' },
  { id:'s_se_intuniv',   label:'Side Effects: Intuniv' },
  { id:'s_se_catapres',  label:'Side Effects: Catapres' },
];

// Track which sections are excluded
const sectionExcluded = {};

function buildSectionBubbles() {
