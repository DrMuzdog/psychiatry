// Track which presets are currently active
const activePresets = {};

function togglePreset(name, btn) {
  const ids = PRESETS[name];
  if (!ids) return;
  const isActive = !!activePresets[name];

  if (isActive) {
    // Deactivate: re-exclude any section that isn't in another active preset
    activePresets[name] = false;
    btn.classList.remove('active');
    ids.forEach(id => {
      // Only re-exclude if no other active preset includes this id
      const stillNeeded = Object.entries(activePresets).some(([pName, pActive]) =>
        pActive && PRESETS[pName] && PRESETS[pName].includes(id)
      );
      if (!stillNeeded) setSectionExcluded(id, true);
    });
  } else {
    // Activate: include all sections in this preset
    activePresets[name] = true;
    btn.classList.add('active');
    ids.forEach(id => setSectionExcluded(id, false));
  }
}

function setSectionExcluded(id, exclude) {
  if (sectionExcluded[id] === exclude) return;
  sectionExcluded[id] = exclude;
  const bubble = document.getElementById('bubble-' + id);
  const btn = document.getElementById('excl-btn-' + id);
  const content = bubble ? bubble.querySelector('.bubble-content') : null;
  if (!bubble || !btn) return;
  if (exclude) {
    bubble.style.opacity = '0.4';
    // Never block pointer events on the bubble itself — iOS Safari ignores
    // pointer-events:auto on child elements when parent has none.
    // Instead disable only the content area, keep button always tappable.
    if (content) content.style.pointerEvents = 'none';
    btn.style.borderColor = '#888';
    btn.style.background = '#e8e8e8';
    btn.style.color = '#555';
    btn.innerHTML = '&#8634; Include';
  } else {
    bubble.style.opacity = '1';
    if (content) content.style.pointerEvents = 'none'; // content is always non-interactive
    btn.style.borderColor = '#C00000';
    btn.style.background = '#fff0f0';
    btn.style.color = '#C00000';
    btn.innerHTML = '&#10005; Exclude';
  }
}

